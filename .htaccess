# Serve the web app manifest with its correct MIME type
AddType application/manifest+json .webmanifest

# Canonical host: www duplicates the apex with a 200; redirect it
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.shopinecom\.com$ [NC]
RewriteRule ^(.*)$ https://shopinecom.com/$1 [R=301,L]
</IfModule>

# Internal artifacts must not be publicly readable: the legacy bundles still
# contain pre-launch content (dead video ids, placeholder testimonials) and the
# README is an internal handoff document.
<IfModule mod_alias.c>
RedirectMatch 404 ^/(dist|reference-build)(/|$)
RedirectMatch 404 ^/README\.md$
</IfModule>
